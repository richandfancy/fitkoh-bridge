{
  "name": "fitkoh-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm dev:client\" \"pnpm dev:worker\"",
    "dev:client": "vite",
    "dev:worker": "wrangler dev worker/src/index.ts --local --port 8787",
    "build": "vite build",
    "deploy:staging": "pnpm build && wrangler deploy -e staging -c worker/wrangler.toml",
    "deploy:production": "pnpm build && wrangler deploy -c worker/wrangler.toml",
    "db:migrate": "wrangler d1 migrations apply fitkoh-bridge-db --local -c worker/wrangler.toml",
    "db:migrate:remote": "wrangler d1 migrations apply fitkoh-bridge-db --remote -c worker/wrangler.toml",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.2.4",
    "@hono/zod-validator": "^0.7.6",
    "@scalar/hono-api-reference": "^0.10.7",
    "@sentry/cloudflare": "^10.49.0",
    "clsx": "^2.1.1",
    "hono": "^4.12.3",
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "wouter": "^3.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260305.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wrangler": "^4.68.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
  }
}